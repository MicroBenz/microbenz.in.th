---
import dayjs from 'dayjs';
import type { CollectionEntry } from 'astro:content';
import { Image } from "astro:assets";

type Props = { blog: CollectionEntry<'blog'>; featured?: boolean };

const { blog, featured = false } = Astro.props;
const tag = blog.data.tags?.[0];
---

{featured ? (
	<article class="grid grid-cols-1 md:grid-cols-[1.2fr_1fr] bg-white border border-[#EDEDEE] rounded-[20px] overflow-hidden shadow-[0_4px_12px_rgba(23,48,87,0.08)] hover:shadow-[0_12px_32px_rgba(23,48,87,0.12)] transition-shadow cursor-pointer">
		<div class="aspect-[1400/751] md:aspect-auto overflow-hidden md:min-h-full">
			<Image src={blog.data.featuredImage} alt={blog.data.title} class="w-full h-full object-cover" />
		</div>
		<div class="p-9 flex flex-col justify-center">
			<div class="flex gap-2.5 mb-3 items-center flex-wrap">
				{tag && <span class="bg-[#ECF2F9] text-space-cadet px-3 py-1 rounded-full text-xs font-medium">{tag}</span>}
				<span class="text-[13px] text-[#9A9AA0]">{dayjs(blog.data.date).format('D MMM YYYY')}</span>
			</div>
			<h2 class="font-thai font-bold text-[26px] md:text-[30px] leading-snug tracking-tight text-space-cadet mb-2">{blog.data.title}</h2>
			<div class="mt-5 text-[14px] font-semibold text-celestial-blue flex items-center gap-1.5">Read post →</div>
		</div>
	</article>
) : (
	<article class="bg-white border border-[#EDEDEE] rounded-2xl overflow-hidden shadow-[0_4px_12px_rgba(23,48,87,0.08)] hover:shadow-[0_12px_32px_rgba(23,48,87,0.12)] transition-shadow cursor-pointer flex flex-col h-full">
		<div class="aspect-[1400/751] overflow-hidden">
			<Image src={blog.data.featuredImage} alt={blog.data.title} class="w-full h-full object-cover" />
		</div>
		<div class="p-5 flex flex-col flex-1">
			<div class="flex gap-2.5 mb-2.5 items-center flex-wrap">
				{tag && <span class={`px-3 py-1 rounded-full text-xs font-medium ${tag === 'Photography' ? 'bg-[#FBDAD6] text-[#B43A2D]' : 'bg-[#ECF2F9] text-space-cadet'}`}>{tag}</span>}
				<span class="text-xs text-[#9A9AA0]">{dayjs(blog.data.date).format('D MMM YYYY')}</span>
			</div>
			<h3 class="font-thai font-bold text-xl leading-snug tracking-tight text-space-cadet">{blog.data.title}</h3>
		</div>
	</article>
)}
