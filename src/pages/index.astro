---
import { getCollection } from 'astro:content';
import BlogCard from '../components/card/BlogCard.astro';
import PageLayout from '../layouts/PageLayout.astro';

const allBlogs = await getCollection('blog');
const blogs = allBlogs.filter(b => b.data.published !== false).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const featured = blogs[0];
const rest = blogs.slice(1);

const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Benz',
	url: 'https://microbenz.in.th',
	description: 'Personal blog covering tech, life, gaming, and more',
};
---

<PageLayout schema={personSchema}>
	<!-- Hero -->
	<section class="grid grid-cols-1 md:grid-cols-[1.1fr_1fr] gap-14 md:gap-16 items-center py-16 md:py-12 mb-2">
		<div>
			<div class="eyebrow mb-3.5">Life · Tech · Gaming · ETC</div>
			<h1 class="font-bold text-[52px] md:text-[64px] leading-[1.05] tracking-[-0.025em] text-space-cadet mb-5">My personal<br/>sharing space.</h1>
			<p class="font-thai text-lg md:text-[19px] leading-[1.75] text-[#0E1B33] max-w-[520px] mb-8">
				This is my space to write — about anything on my mind.
			</p>
			<!-- <div class="flex gap-3 flex-wrap">
				<a href="#latest" class="bg-space-cadet text-white px-6 py-3 rounded-[10px] font-semibold text-[15px] hover:bg-[#2B4370] transition-colors">Read the blog →</a>
				<a href="/about" class="bg-transparent text-space-cadet border border-space-cadet px-6 py-3 rounded-[10px] font-semibold text-[15px] hover:bg-space-cadet hover:text-white transition-colors">About Benz</a>
			</div> -->
		</div>
		<!-- Desktop Image (temporary hidden) -->
		<!-- <div class="relative aspect-[4/5] rounded-[24px] overflow-hidden shadow-[0_12px_32px_rgba(23,48,87,0.18)] hidden md:block">
			<img src="/assets/images/photo-benz-rocks.png" alt="Benz" class="w-full h-full object-cover" fetchpriority="high" loading="eager" />
			<img src="/assets/logo/symbol-white.png" alt="" class="absolute bottom-4 right-4 w-11 opacity-90" />
		</div> -->
	</section>

	<!-- Latest writing -->
	<section id="latest">
		<div class="flex items-baseline justify-between mb-5">
			<h2 class="font-bold text-[32px] md:text-[34px] tracking-[-0.02em] text-space-cadet">Latest writing</h2>
			<!-- <a href="/" class="text-sm font-semibold text-celestial-blue hover:text-space-cadet transition-colors flex items-center gap-1.5">All posts →</a> -->
		</div>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-5">
			<a href={`/blog/${featured.data.slug ?? featured.id.split('/')[0]}`} class="col-span-1 md:col-span-3">
				<BlogCard blog={featured} featured />
			</a>
			{rest.map((blog) => (
				<a href={`/blog/${blog.data.slug ?? blog.id.split('/')[0]}`} class="h-full">
					<BlogCard blog={blog} />
				</a>
			))}
		</div>
	</section>
</PageLayout>
