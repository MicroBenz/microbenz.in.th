---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import BlogCard from '../../components/card/BlogCard.astro';
import dayjs from 'dayjs';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => {
		const slug = post.data.slug ?? post.id.split('/')[0];
		return {
			params: { slug },
			props: { post, allPosts: posts },
		};
	});
}

interface Props {
	post: CollectionEntry<'blog'>;
	allPosts: CollectionEntry<'blog'>[];
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);

const tag = post.data.tags?.[0];

const others = allPosts
	.filter(p => p.id !== post.id)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 2);
---

<PageLayout title={`${post.data.title} - เบนซ์เขียนบล็อกนะจ๊ะ`} featuredImage={post.data.featuredImage.src} fullWidth>
	<!-- Post hero -->
	<div class="relative w-full aspect-[1400/751] min-h-[280px] overflow-hidden">
		<img src={post.data.featuredImage.src} alt={post.data.title} class="w-full h-full object-cover" />
		<div class="absolute inset-0 bg-gradient-to-b from-transparent from-[40%] to-[rgba(23,48,87,0.85)]"></div>
		<div class="absolute bottom-10 md:bottom-12 left-0 right-0 max-w-[880px] mx-auto px-6 md:px-10 text-white">
			<div class="flex gap-2.5 mb-4 items-center flex-wrap">
				{tag && <span class="bg-bittersweet text-white px-3 py-1 rounded-full text-xs font-semibold">{tag}</span>}
				<span class="text-sm opacity-85">{dayjs(post.data.date).format('D MMM YYYY')}</span>
			</div>
			<h1 class="font-thai font-bold text-[40px] md:text-[56px] leading-[1.1] tracking-[-0.02em] text-white">{post.data.title}</h1>
		</div>
	</div>

	<!-- Post body -->
	<article class="bg-white">
		<div class="max-w-[680px] mx-auto px-6 py-14 md:py-16">
			<div class="w-full max-w-full prose prose-lg md:prose-xl text-space-cadet">
				<Content />
			</div>
		</div>

		<!-- Author byline -->
		<div class="max-w-[680px] mx-auto px-6 pb-10">
			<div class="border-t border-[#DCDCDE] pt-7 flex items-center gap-4">
				<div class="w-11 h-11 rounded-full bg-main-bg flex items-center justify-center flex-shrink-0 p-2">
					<img src="/assets/logo/symbol-navy.png" alt="MicroBenz" class="w-full h-full" />
				</div>
				<div>
					<div class="font-semibold text-[15px] text-space-cadet">Written by Benz</div>
					<div class="text-[13px] text-[#5E5E66]">microbenz.in.th</div>
				</div>
			</div>
		</div>
	</article>

	<!-- Keep reading -->
	{others.length > 0 && (
		<div class="bg-main-bg py-12 md:py-16 px-6 md:px-10">
			<div class="max-w-[1280px] mx-auto">
				<div class="eyebrow mb-3.5">Keep reading</div>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
					{others.map(p => (
						<a href={`/blog/${p.data.slug ?? p.id.split('/')[0]}`} class="h-full">
							<BlogCard blog={p} />
						</a>
					))}
				</div>
			</div>
		</div>
	)}
</PageLayout>
